<tr{% if new %} class="new"{% endif %} id="li-{{ item.callback_id }}"><td><span class="tag {% if item.type == "email" %}email{% else %}phone{% endif %}">{{ item.type }}</span></td><td class="val">{{ item.value }}</td><td class="mono-id">{{ item.username }}</td><td class="mono-id">{{ item.user_id }}</td><td><button class="btn-danger" data-on-click="@delete('/www/li/{{ item.callback_id }}')">Remove</button></td></tr>
