<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>LDF · {% block title %}Console{% endblock %}</title>
  <link rel="stylesheet" href="/assets/css/ldf.css">
  <script type="module" src="/assets/js/datastar.js"></script>
</head>
<body>
  <div class="shell">
    <header class="topbar">
      <div class="brand"><b>LDF</b><span>ETSI&nbsp;103707</span></div>
      <nav class="nav">
        <a href="/www/receiver"{% if active == "receiver" %} class="active"{% endif %}>Receiver</a>
        <a href="/www/admin"{% if active == "admin" %} class="active"{% endif %}>Listeners</a>
        <a href="/www/history"{% if active == "history" %} class="active"{% endif %}>History</a>
      </nav>
      <div class="live-pill">{% if live %}<span class="dot"></span> Stream live{% else %}Standby{% endif %}</div>
    </header>
    {% block content %}{% endblock %}
  </div>
</body>
</html>
