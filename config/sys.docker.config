%% -*- mode: erlang;erlang-indent-level: 4;indent-tabs-mode: nil -*-

[
    {kernel, [
        {logger_level, debug}
    ]},
    {kura, [
        {repos, #{
            ldf_repo => #{
                backend => kura_backend_postgres,
                host => "localhost",
                port => 5555,
                database => "ldf",
                user => "postgres",
                password => "root",
                pool_size => 2
            }
        }}
    ]},
    {pg_types, [
        {uuid_format, string},
        {json_config, {json, [maps, binary], [maps, binary, atom_keys]}}
    ]},
    {nova, [
        {cowboy_configuration, #{
            port => 8095
        }},
        {dev_mode, true},
        %% Bootstraps the application
        {bootstrap_application, ldf},
        %% Plugins is written on form {RequestType, Module, Options, Priority}
        %% Priority is that the lowest number is executed first
        {plugins, [
            {pre_request, nova_request_plugin, #{
                decode_json_body => true, parse_bindings => true, parse_qs => true
            }}
        ]}
    ]},
    {ldf, [
        {chatli_path, <<"http://localhost:8090/v1">>},
        {chatli_public_path, <<"http://localhost:8090/v1">>},
        {ldf_callback, <<"http://localhost:8095/receiver">>}
    ]}
    %% Please change your app.src-file instead if you intend to add app-specific configurations
].
